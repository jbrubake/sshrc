# abstract: Bring your .bashrc, .vimrc, etc. with you when you ssh 
#
# A heavily modified version of Russell Stewart's original
# (https://github.com/cdown/sshrc) with additional ideas taken from
# taylorskalyo's fork (https://github.com/taylorskalyo/sshrc)
#
# shellcheck disable=SC2016 (Expressions don't expand in single quotes)
#
# Defaults {{{1
#
# Path to your sshrc configuration
SSHRC_HOME=${SSHRC_HOME:=${XDG_CONFIG_HOME:-"$HOME/.config"}/sshrc}
ARG_MAX=1024     # Maximum allowable ssh command argument size in KiB
DO_LOGIN=false;  # Process remote login shell files
DO_TMUX=false;   # Include tmuxrc framework

# Documentation {{{1
#
VERSION=2.0

print_version() { # {{{2
    cat <<END
$(basename "$0") $VERSION
Copyright (C) 2026 Orion Arts
License GPLv3+: GNU GPL version 3 or later <https://gnu.org/licenses/gpl.html>.
This is free software: you are free to change and redistribute it.
There is NO WARRANTY, to the extent permitted by law.

Written by Jeremy Brubaker.
END
} >&2

print_help() { # {{{2
    cat <<END
Usage: $(basename "$0") [OPTION] [SSH OPTION] ssh_args ...

Bring your .bashrc, .vimrc, etc. with you when you ssh 

  -j         sshrc will process local login shell files
  -u         setup tmuxrc using the unique system identifier
  -U [ID]    setup tmuxrc using ID as the unique identifier
  -d         display the unique system identifier used by tmuxrc
  -Z [SIZE]  set maximum the ssh command argument size in KiB
               (Default: $ARG_MAX KiB)
  -z         print size of the ssh command argument and exit
  -h         display this help
END
} >&2

# Process options {{{1
#
# Location of the unique tmuxrc ID
# This file should not be deleted or edited
tmuxrc_id_file=${XDG_STATE_HOME:-~/.local/state}/sshrc-tmuxrc-id

# Get (setting if necessary) the tmuxrc ID
[ -r "$tmuxrc_id_file" ] || mktemp -u XXXXXX > "$tmuxrc_id_file"
TMUX_ID=$(cat "$tmuxrc_id_file")

# Print ssh argument size and exit if true
CHECK_SIZE=false

# All options not used by ssh are accepted so I don't have to keep searching
# through the manpage
while getopts ':dHjruU:zZ:hV' opt; do
    case $opt in
        d) cat "$tmuxrc_id_file"; exit ;;
        H) ;; # place holder for exapansion
        j) DO_LOGIN=true ;;
        r) ;; # place holder for exapansion
        u) DO_TMUX=true ;;
        U) DO_TMUX=true; TMUX_ID=${OPTARG:-$TMUX_ID} ;;
        z) CHECK_SIZE=true ;;
        Z) ARG_MAX=$OPTARG ;;
        h) print_help; exit ;;
        V) print_version; exit ;;
        :) # Print an error for missing arguments
            printf -- '-%s requires an argument\n' "$OPTARG" >&2
            print_help
            exit 1
            ;;
        *) printf 'Invalid option: %s\n' "$opt" >&2
            print_help
            exit 1
            ;;
    esac
done
shift $((OPTIND-1))
OPTIND=1

# Functions {{{1
#
# minify {{{2
#
# Minify the input by
#
# - stripping leading whitespace
# - printing anything that looks like a shebang (which can be found anywhere)
# - deleting full line comments
# - deleting blank lines
#
minify() {
    sed -e 's/^[[:space:]]*//g' \
        -e '/^#!/p' \
        -e '/^#/d' \
        -e '/^$/d'
}

# ssh argument command size functions {{{2
#
# Check to see if a string is larger than $ARG_MAX KiB
#
# Arguments:
#   $1: string to check
#
# stdout:
#   0: size is ok
#   N: size is too large, N == size in B
#
check_cmd_size() {
    size=$(get_byte_size "$1")

    if [ "$size" -le "$((ARG_MAX * 1024))" ]; then
        echo 0
    else
        echo "$size"
    fi
}

# Print size of $1 in B
#
get_byte_size() { LC_ALL=C printf %s "$1" | wc -c; }

# Convert B to KiB
#
b2kib() { echo "scale=2; $1 / 1024" | bc -l; }

# make_stage_2 {{{2
#
# Print a compressed script that will setup the remote environment
# and then run a new shell with that environment
#
make_stage_2() {
    # Compress your sshrc configuration
    files=$(tar c -hC "$(dirname "$1")" "$(basename "$1")" | openssl enc -base64)

    # Load login shell profile {{{3
    #
    unset login
    if "$DO_LOGIN"; then
        login='
            [ -r /etc/profile ] && . /etc/profile

            for f in .bash_{profile,login} .profile; do
                [ -r ~/\$f ] && . ~/\$f && break
            done
            '
    fi

    # Setup tmuxrc {{{3
    #
    unset tmux_framework tmux_aliases tmux_copy
    if "$DO_TMUX"; then
        # Setup tmuxrc framework during initial login
        #
        tmux_framework='
            # Directory tree for tmuxrc socket and sshrc configuration to
            # persist through a tmux session. TMUX_TMPDIR is ignored for
            # simplicity
            tmux_id='$TMUX_ID'
            tmuxbase=$tmux_tmp-$tmux_id
            tmuxrc=$tmuxbase/sshrc

            # Name of the tmux socket
            tmuxsock=tmuxrc

            # Create with proper permissions if necessary
            mask=$(umask)
            umask 0077
            mkdir -p "$tmuxrc"
            umask "$mask"

            # Create a stub tmuxrc configuration
            #
            cat > "$tmuxrc/../tmuxrc.conf" <<END
                # Try to load an sshrc tmux.conf. Fallback to the default config
                if-shell "[ -f '\''\$SSHRC/tmux.conf'\'' ]" \
                    { source-file "\$SSHRC/tmux.conf" } \
                    { source-file ~/.tmux.conf }

                # Use the bash wrapper so the sshrc configuration is loaded
                # Set this after loading the user configuration in case the user
                # missed the warning to **not** set this option
                set-option -g default-command "\$SSHRC/../bash"
            END'

        # - Alias tmux to use the tmuxrc framework
        # - Create an alias to get the TMUX_ID for multi-user tmuxrc
        #
        tmux_aliases='
            alias tmux="tmuxrc $tmux_id"
            alias tmux_id="echo $tmux_id"
            '

        # If there are no existing tmux sessions, copy all sshrc files to a
        # persistent tmuxrc directory just before spawning the initial sshrc
        # shell
        tmux_copy='command tmux -S "$tmuxbase/$tmuxsock" ls >/dev/null 2>&1 || cp -r "$base"/. "$tmuxrc/.."'
    fi

    # Create the stage_2 script {{{3
    #
                        # awk '\''{print "Last login:",\$4,\$5,\$6,\$7,\$8,\"from\",\$3;}'\''
    printf '
        # Create a remote directory for your sshrc configuration
        #
        # base: where to put sshrc framework. Sometimes this is accessed as
        #   $SSHRC/.. because SSHRC may change which would have required
        #   exporting and overriding an additional variable.
        # SSHRC: where to put your sshrc configuration
        #
        # SSHRC is the only exported path because tmuxrc needs to override it.
        # All other paths end up hardcoded so they cannot be overriden
        #
        base="$(mktemp -d --tmpdir "sshrc-$(id -un).XXXXXXXXXX")"
        export SSHRC=$base/sshrc
        mkdir "$SSHRC"

        # Setup tmuxrc framework
        # $tmux_tmp is needed by the tmuxrc function below
        #
        tmux_tmp=/tmp/tmux-$(id -u)
        # tmux_framework
        %s

        # Create a bash rcfile to load the sshrc framework (Any variables that
        # should be interpolated when the file is *sourced* must be escaped)
        #
        cat > "$base/config" <<END
            # Things that are only done in the initial shell
            #
            if [ -z "\$_SSHRC_LOGIN" ]; then
                _sshrc_cleanup() {
                    # Remove the sshrc framework on exit
                    rm -rf "$base"

                    # Remove the tmuxrc framework on exit if there are no
                    # existing tmux sessions. $tmuxbase is null if the tmuxrc
                    # framework is not installed
                    if [ -n "$tmuxbase" ]; then
                        command tmux -S "$tmuxbase/$tmuxsock" ls >/dev/null 2>&1 || rm -r "$tmuxbase"
                    fi
                }
                trap _sshrc_cleanup EXIT

                # Print motd unless hushed
                # (This does not honor the sshd PrintMotd setting)
                #
                if ! [ -f ~/.hushlogin -o -f "\$SSHRC/.hushlogin" ]; then
                    [ -r /etc/motd ] && cat /etc/motd
                    [ -r /etc/update-motd.d ] run-parts /etc/update-motd.d 2>/dev/null
                    command -v last 2>/dev/null &&
                        last -F $(id -un) 2>/dev/null |
                            grep -v "still logged in" | head -n1 |
                            awk '\''{print "Last login:",\$4,\$5,\$6,\$7,\$8,\"from\",\$3;}'\''
                fi

                # Load login shell profile
                %s

                # Suppress this block in future shells
                export _SSHRC_LOGIN=1
            fi

            # Load your sshrc configuration
            [ -r "\$SSHRC/sshrc" ] && . "\$SSHRC/sshrc"

            # Create tmux wrapper
            %s

            # If DO_TMUX is true, tmuxrc is called by the tmux alias. If DO_TMUX
            # is false, tmuxrc is used interactively to connect to an existing
            # tmuxrc server. The first argument is the unique ID of the tmuxrc
            # server you want to use
            #
            tmuxrc() {
                # Set tmuxrc directory based on ID
                tmuxbase="$tmux_tmp-\$1"; shift

                # - Set SSHRC to the persistent $tmuxrc
                # - Use a custom socket
                # - Load the tmuxrc config (which will load your actual config)
                SSHRC=\$tmuxbase/sshrc command tmux -S "\$tmuxbase/tmuxrc" -f "\$tmuxbase/tmuxrc.conf" "\$@"
            }

            # Interactive calls to bash load your sshrc configuration
            alias bash="\$SSHRC/../bash"
        END

        # Extract the sshrc configuration to the remote directory
        #
        echo "%s" | openssl enc -base64 -d | tar -xC "$SSHRC" --strip-components 1

        # Create a bash wrapper to load sshrc configuration
        #
        cat > "$base/bash" <<END
            exec /bin/bash --rcfile \"\$SSHRC/../config\" \"\$@\"
        END
        chmod +x "$base/bash"

        # Copy sshrc stuff so it is not deleted when the initial shell exits
        #
        %s

        # Using exec sets SHLVL == 1 like a real login
        # env -i clears anything that was done by the initial login profile
        # The variables set are necessary for a functional shell
        #
        exec env -i \
            HOME="$HOME" \
            LOGNAME="$LOGNAME" \
            SSHRC="$SSHRC" \
            SSH_CLIENT="$SSH_CLIENT" \
            SSH_CLIENT2="$SSH_CLIENT2" \
            SSH_TTY="$SSH_TTY" \
            TERM=xterm \
            "$base/bash"
        ' "$tmux_framework" "$login" "$tmux_aliases" "$files" "$tmux_copy" |
            # Any compression and encoding done here must
            # be reversed **inside** the stage_1 script
            minify | gzip | openssl enc -base64
}

# make_stage_1 {{{2
#
# Print a script that will bootstrap the compressed bash wrapper
#
make_stage_1() {
    printf '
        if ! command -v openssl >/dev/null; then
            echo "Remote openssl not found!" >&2
            exit 1
        fi

        # Reverse encoding and compression and run stage_2
        eval "$(echo "%s" | openssl enc -base64 -d | gunzip)"
        ' "$1" | minify
}

# Main {{{1
#
if ! [ -d "$SSHRC_HOME" ]; then
    printf '$SSHRC_HOME does not exist: %s\n' "$SSHRC_HOME" >&2
    exit 1
fi

stage_2=$(make_stage_2 "$SSHRC_HOME")
stage_1=$(make_stage_1 "$stage_2")

# Print stage_1 size if requested
if [ "$CHECK_SIZE" = true ]; then
    printf 'sshrc stage_1 command is %s KiB\n' "$(b2kib "$(get_byte_size "$stage_1")")"
else
    size=$(check_cmd_size "$stage_1")

    # Abort if stage_1 size is too big
    if [ "$size" != 0 ]; then
        printf 'Error: stage_1 command size (%s KiB) is greater than %s KiB\n' "$(b2kib "$size")" "$ARG_MAX"
        exit 1
    else
        exec ssh -t "$@" "$stage_1"
    fi
fi

